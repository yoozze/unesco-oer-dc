{#
/**
 * @file
 * Theme override for a views mini-pager.
 */
#}
{% if items.previous or items.next or items.current %}
    <nav class="c-pager c-pager--mini" role="navigation" aria-labelledby="{{ heading_id }}">
        <{{ pagination_heading_level }} id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</{{ pagination_heading_level }}>
        <ul class="c-pager__items js-pager__items">
            {% if items.previous %}
                <li class="c-pager__item c-pager__item--previous">
                    <a class="c-pager__link c-button c-button--outlined" href="{{ items.previous.href }}" title="{{ 'Go to previous page'|t }}" rel="prev"{{ items.previous.attributes|without('href', 'title', 'rel') }}>
                        {{ svg_icon('navigate-before', 'c-button__leading-icon') }}
                        <span class="visually-hidden">{{ 'Previous page'|t }}</span>
                    </a>
                </li>
            {% endif %}
            {% if items.current %}
                <li class="c-pager__item is-active">
                    <span class="c-pager__link c-pager__link--number c-button c-button--outlined is-active" aria-current="page">
                        {% trans %}Page {{ items.current }}{% endtrans %}
                    </span>
                </li>
            {% endif %}
            {% if items.next %}
                <li class="c-pager__item c-pager__item--next">
                    <a class="c-pager__link c-button c-button--outlined" href="{{ items.next.href }}" title="{{ 'Go to next page'|t }}" rel="next"{{ items.next.attributes|without('href', 'title', 'rel') }}>
                        <span class="visually-hidden">{{ 'Next page'|t }}</span>
                        {{ svg_icon('navigate-next', 'c-button__trailing-icon') }}
                    </a>
                </li>
            {% endif %}
        </ul>
    </nav>
{% endif %}
