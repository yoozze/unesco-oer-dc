{#
/**
 * @file
 * Theme override for a selected media library item.
 */
#}
{%
  set classes = [
    'media-library-item',
    'media-library-item--grid',
  ]
%}
<div{{ attributes.addClass(classes) }}>
    {% if content.remove_button %}
        <div class="media-library-item__remove">
            {{ content.remove_button }}
        </div>
    {% endif %}
    {% if content.weight %}
        {{ content.weight }}
    {% endif %}
    {% if content.rendered_entity %}
        <div class="media-library-item__preview js-media-library-item-preview">
            {{ content.rendered_entity }}
        </div>
    {% endif %}
    {{ content.target_id }}
</div>
