{#
/**
 * @file
 * Theme override of a datetime form wrapper.
 *
 * Available variables:
 * - content: The form element to be output, usually a datelist, or datetime.
 * - title: The title of the form element.
 * - title_attributes: HTML attributes for the title wrapper.
 * - description: Description text for the form element.
 * - required: An indicator for whether the associated form element is required.
 *
 * @see template_preprocess_datetime_wrapper()
 */
#}
{%
  set title_classes = [
    'c-form__label',
    required ? 'c-form__label--required',
  ]
%}
{%
  set description_classes = [
    'c-form__field-description',
  ]
%}
<div class="c-form__field c-form__field--type_datetime">
	<div class="c-form__control c-form__control--type_datetime">
		{{ content }}
		{% if title %}
			<label{{title_attributes.addClass(title_classes)}}>
				<span>{{ title }}</span>
			</label>
		{% endif %}
	</div>
	{% if errors %}
		<div class="c-form__field-error">
			{{ errors }}
		</div>
	{% endif %}
	{% if description %}
		<div{{description_attributes.addClass(description_classes)}}>
			{{ description }}
		</div>
	{% endif %}
</div>
